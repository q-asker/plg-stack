{
  "uid": "cb-tuning",
  "title": "Circuit Breaker 튜닝",
  "description": "Resilience4j 서킷브레이커 임계값(slow/failure rate, min-calls, window) 튜닝 의사결정 전용 대시보드. 분포 측정·통계적 외삽·평가 메커니즘 가시화에 책임 범위 한정. 비용/일반 API RPS 등 운영 모니터링은 별도 대시보드 책임.",
  "tags": ["circuit-breaker", "tuning", "resilience4j"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {"refresh_intervals": ["30s", "1m", "5m", "15m", "1h"]},
  "templating": {
    "list": [
      {
        "name": "rate_window",
        "type": "custom",
        "label": "Rate Window",
        "query": "5m,15m,1h,6h,24h,7d",
        "current": {"text": "1h", "value": "1h"},
        "options": [
          {"text": "5m", "value": "5m", "selected": false},
          {"text": "15m", "value": "15m", "selected": false},
          {"text": "1h", "value": "1h", "selected": true},
          {"text": "6h", "value": "6h", "selected": false},
          {"text": "24h", "value": "24h", "selected": false},
          {"text": "7d", "value": "7d", "selected": false}
        ]
      },
      {
        "name": "quiz_type",
        "type": "query",
        "label": "Quiz Type",
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "query": "label_values(quiz_generation_outcome_total, quiz_type)",
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 100, "type": "row", "title": "1. Circuit Health",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 1, "title": "Current State (OPEN?)", "type": "stat",
      "gridPos": {"x": 0, "y": 1, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "max(resilience4j_circuitbreaker_state{name=\"aiServer\", state=\"open\"})",
        "instant": true
      }],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background", "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "CLOSED", "color": "green"}}},
            {"type": "value", "options": {"1": {"text": "OPEN", "color": "red"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "red", "value": 1}
          ]}
        }
      }
    },
    {
      "id": 2, "title": "State Timeline (all states)", "type": "state-timeline",
      "gridPos": {"x": 6, "y": 1, "w": 12, "h": 5},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "resilience4j_circuitbreaker_state{name=\"aiServer\"} > 0",
        "legendFormat": "{{state}}"
      }],
      "options": {"showValue": "auto", "mergeValues": true}
    },
    {
      "id": 3, "title": "Failure Rate (%) — threshold 30", "type": "gauge",
      "gridPos": {"x": 18, "y": 1, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "max(resilience4j_circuitbreaker_failure_rate{name=\"aiServer\"})",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 15},
            {"color": "red", "value": 30}
          ]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 4, "title": "Slow Call Rate (%) — threshold 70", "type": "gauge",
      "gridPos": {"x": 21, "y": 1, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "max(resilience4j_circuitbreaker_slow_call_rate{name=\"aiServer\"})",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 50},
            {"color": "red", "value": 70}
          ]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 200, "type": "row", "title": "2. TTFQ Distribution (measured + estimated)",
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 5, "title": "TTFQ measured (p50 / p95)", "type": "timeseries",
      "gridPos": {"x": 0, "y": 7, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gemini_request_first_quiz_duration_seconds_bucket[$rate_window])))",
          "legendFormat": "p50 (measured)"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gemini_request_first_quiz_duration_seconds_bucket[$rate_window])))",
          "legendFormat": "p95 (measured)"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 6, "title": "TTFQ estimated p99 (log-normal vs Pareto α=2.21)", "type": "timeseries",
      "gridPos": {"x": 12, "y": 7, "w": 12, "h": 8},
      "description": "log-normal: 30s 이하 분포 fit. Pareto: 30s 초과 꼬리 fit (Heavy-tail 보강). slow threshold=60s 선 표시.",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "refId": "A",
          "expr": "exp(ln(histogram_quantile(0.95, sum by (le) (rate(gemini_request_first_quiz_duration_seconds_bucket[$rate_window])))) * 1.4136 + ln(histogram_quantile(0.50, sum by (le) (rate(gemini_request_first_quiz_duration_seconds_bucket[$rate_window])))) * -0.4136)",
          "legendFormat": "p99 (log-normal estimate)"
        },
        {
          "refId": "B",
          "expr": "30 * ( ((sum(increase(gemini_request_first_quiz_duration_seconds_count[$rate_window])) - sum(increase(gemini_request_first_quiz_duration_seconds_bucket{le=\"30.0\"}[$rate_window]))) / sum(increase(gemini_request_first_quiz_duration_seconds_count[$rate_window]))) / 0.01 ) ^ (1/2.21)",
          "legendFormat": "p99 (Pareto estimate)"
        },
        {
          "refId": "C",
          "expr": "30 * ( ((sum(increase(gemini_request_first_quiz_duration_seconds_count[$rate_window])) - sum(increase(gemini_request_first_quiz_duration_seconds_bucket{le=\"30.0\"}[$rate_window]))) / sum(increase(gemini_request_first_quiz_duration_seconds_count[$rate_window]))) / 0.001 ) ^ (1/2.21)",
          "legendFormat": "p99.9 (Pareto estimate)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "thresholdsStyle": {"mode": "line"}
          },
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "transparent", "value": null},
            {"color": "red", "value": 60}
          ]}
        }
      }
    },
    {
      "id": 7, "title": "Slow threshold exceedance ratios (%)", "type": "timeseries",
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8},
      "description": "30s 직접 측정 + 60s Pareto 외삽. 1% 선이 임계 위험 신호.",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(increase(gemini_request_first_quiz_duration_seconds_count[$rate_window])) - sum(increase(gemini_request_first_quiz_duration_seconds_bucket{le=\"30.0\"}[$rate_window]))) / sum(increase(gemini_request_first_quiz_duration_seconds_count[$rate_window]))",
          "legendFormat": "P(TTFQ>30s) measured"
        },
        {
          "refId": "B",
          "expr": "100 * 2^(-2.21) * (sum(increase(gemini_request_first_quiz_duration_seconds_count[$rate_window])) - sum(increase(gemini_request_first_quiz_duration_seconds_bucket{le=\"30.0\"}[$rate_window]))) / sum(increase(gemini_request_first_quiz_duration_seconds_count[$rate_window]))",
          "legendFormat": "P(TTFQ>60s) Pareto estimate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.7},
            {"color": "red", "value": 1.0}
          ]},
          "custom": {"thresholdsStyle": {"mode": "line"}}
        }
      }
    },
    {
      "id": 8, "title": "TTFQ _max observed (heavy-tail watch)", "type": "timeseries",
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8},
      "description": "실측 max 추적. 119s baseline 초과 시 fat-tail 심화 시그널.",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "refId": "A",
          "expr": "max by (max_chunks) (max_over_time(gemini_request_first_quiz_duration_seconds_max[$rate_window]))",
          "legendFormat": "max_chunks={{max_chunks}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "transparent", "value": null},
            {"color": "orange", "value": 119},
            {"color": "red", "value": 180}
          ]},
          "custom": {"thresholdsStyle": {"mode": "line+area"}}
        }
      }
    },

    {
      "id": 300, "type": "row", "title": "3. Call Outcomes",
      "gridPos": {"x": 0, "y": 23, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 9, "title": "Calls by kind (rate)", "type": "timeseries",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (kind) (rate(resilience4j_circuitbreaker_calls_seconds_count{name=\"aiServer\"}[$rate_window]))",
        "legendFormat": "{{kind}}"
      }],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}}}}
    },
    {
      "id": 10, "title": "Slow calls cumulative (by kind)", "type": "timeseries",
      "gridPos": {"x": 12, "y": 24, "w": 6, "h": 7},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "resilience4j_circuitbreaker_slow_calls{name=\"aiServer\"}",
        "legendFormat": "slow_{{kind}}"
      }]
    },
    {
      "id": 11, "title": "Not-permitted calls (OPEN block) rate", "type": "timeseries",
      "gridPos": {"x": 18, "y": 24, "w": 6, "h": 7},
      "description": "30일 baseline=0. 1건이라도 발생 시 서킷이 트리거됨.",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "rate(resilience4j_circuitbreaker_not_permitted_calls_total{name=\"aiServer\"}[$rate_window])",
        "legendFormat": "not_permitted"
      }],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 12, "title": "Buffered calls — min-calls=5 line", "type": "timeseries",
      "gridPos": {"x": 0, "y": 31, "w": 12, "h": 7},
      "description": "윈도우 내 평가 가능 표본 수. 5 미만이면 서킷 평가 자체가 발동 안 됨.",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "resilience4j_circuitbreaker_buffered_calls{name=\"aiServer\"}",
        "legendFormat": "buffered_{{kind}}"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 5}
          ]},
          "custom": {"thresholdsStyle": {"mode": "line"}}
        }
      }
    },
    {
      "id": 13, "title": "Calls per second (window-aware)", "type": "timeseries",
      "gridPos": {"x": 12, "y": 31, "w": 12, "h": 7},
      "description": "트래픽 sparse 검증 — sliding-window 720s에서 5건 모이려면 ≥0.007 ops 필요.",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "sum(rate(resilience4j_circuitbreaker_calls_seconds_count{name=\"aiServer\"}[$rate_window]))",
        "legendFormat": "aiServer call rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 0.007}
          ]},
          "custom": {"thresholdsStyle": {"mode": "line"}}
        }
      }
    },

    {
      "id": 400, "type": "row", "title": "4. Trigger-related Signals (CB 입력 정합성)",
      "gridPos": {"x": 0, "y": 38, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 14, "title": "Quiz generation outcome (record-exceptions 정합성)", "type": "timeseries",
      "gridPos": {"x": 0, "y": 39, "w": 12, "h": 7},
      "description": "fail/partial이 GeminiInfraException으로 CB에 카운트되는지 검증. failure-rate 임계(30%) 산정 근거.",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (outcome, quiz_type) (rate(quiz_generation_outcome_total{quiz_type=~\"$quiz_type\"}[$rate_window]))",
        "legendFormat": "{{quiz_type}}/{{outcome}}"
      }],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}}}}
    },
    {
      "id": 15, "title": "Streaming timeout rate (slow=60s vs 5min cap 관계)", "type": "timeseries",
      "gridPos": {"x": 12, "y": 39, "w": 12, "h": 7},
      "description": "5min timeout이 slow=60s 임계보다 먼저 발동하는지 검증. timeout이 잦으면 slow 임계 하향 검토.",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (quiz_type) (rate(gemini_streaming_timeout_total{quiz_type=~\"$quiz_type\"}[$rate_window]))",
        "legendFormat": "{{quiz_type}}"
      }]
    },

    {
      "id": 500, "type": "row", "title": "5. System Resources (fake-slow 배제)",
      "gridPos": {"x": 0, "y": 46, "w": 24, "h": 1}, "collapsed": false
    },
    {
      "id": 18, "title": "JVM heap used + GC pause", "type": "timeseries",
      "gridPos": {"x": 0, "y": 47, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "heap used"
        },
        {
          "refId": "B",
          "expr": "rate(jvm_gc_pause_seconds_sum[$rate_window])",
          "legendFormat": "gc pause/s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 19, "title": "HikariCP connections (active / pending)", "type": "timeseries",
      "gridPos": {"x": 12, "y": 47, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_pending",
          "legendFormat": "pending"
        },
        {
          "refId": "C",
          "expr": "hikaricp_connections_max",
          "legendFormat": "max"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Circuit OPEN events",
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "enable": true,
        "iconColor": "red",
        "expr": "resilience4j_circuitbreaker_state{name=\"aiServer\", state=\"open\"} == 1",
        "titleFormat": "aiServer OPEN"
      }
    ]
  }
}
