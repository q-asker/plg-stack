          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH per_req AS (SELECT reqId, uri, COUNT(*) cnt FROM trace_snapshot WHERE repo='$repo' GROUP BY reqId, uri), top AS (SELECT reqId, ROW_NUMBER() OVER (PARTITION BY uri ORDER BY cnt DESC, reqId) rn FROM per_req) SELECT ts.uri, ts.repo, ts.method, ts.sql_stripped, ts.ms, ts.examined, ts.no_index FROM trace_snapshot ts WHERE ts.repo='$repo' AND ts.reqId IN (SELECT reqId FROM top WHERE rn=1) ORDER BY ts.uri, ts.event_id LIMIT 500",
