        {
            "title": "에러율 (%)",
            "description": "전체 로그 대비 ERROR 비율. 5% 이상이면 주의, 10% 이상이면 위험.",
            "type": "stat",
            "gridPos": { "h": 4, "w": 5, "x": 15, "y": 7 },
            "datasource": {
                "type": "loki",
                "uid": "P8E80F9AEF21F6940"
            },
            "targets": [
                {
                    "expr": "sum(count_over_time({host=~\"$host\", app=~\"$app\", level=\"ERROR\"} |~ \"$search\" [$__auto])) / sum(count_over_time({host=~\"$host\", app=~\"$app\"} |~ \"$search\" [$__auto])) * 100",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "unit": "percent",
                    "decimals": 1,
                    "thresholds": {
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 5 },
                            { "color": "red", "value": 10 }
                        ]
                    }
                }
            },
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "textMode": "value"
            }
        },
        {
            "title": "호스트별 로그 비율",
