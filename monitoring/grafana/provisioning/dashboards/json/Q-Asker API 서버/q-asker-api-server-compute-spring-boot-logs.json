        {
            "title": "상위 에러 패턴 (로거별)",
            "description": "ERROR 로그를 로거별로 그룹화하여 빈도순 정렬. 반복 에러 식별에 활용.",
            "type": "table",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
            "datasource": {
                "type": "loki",
                "uid": "P8E80F9AEF21F6940"
            },
            "targets": [
                {
                    "expr": "topk(10, sum by (logger) (count_over_time({host=~\"$host\", app=~\"$app\", level=\"ERROR\"} |~ \"$search\" | regexp \"(?P<timestamp>\\\\d{4}-\\\\d{2}-\\\\d{2} \\\\d{2}:\\\\d{2}:\\\\d{2}\\\\.\\\\d{3}) (?P<lvl>\\\\w+) (?P<logger>\\\\S+) -\" [$__auto])))",
                    "legendFormat": "{{logger}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "thresholds": {
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 5 },
                            { "color": "red", "value": 20 }
                        ]
                    },
                    "custom": {
                        "align": "auto",
                        "cellOptions": { "type": "color-text" },
                        "inspect": false
                    }
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "logger" },
                        "properties": [
                            { "id": "custom.width", "value": 400 },
                            { "id": "displayName", "value": "로거" }
                        ]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Value" },
                        "properties": [
                            { "id": "displayName", "value": "에러 건수" }
                        ]
                    }
                ]
            },
            "options": {
                "showHeader": true,
                "sortBy": [
                    { "displayName": "에러 건수", "desc": true }
                ],
                "footer": {
                    "show": false
                }
            },
            "transformations": [
                {
                    "id": "sortBy",
                    "options": {
                        "fields": {},
                        "sort": [
                            { "field": "Value", "desc": true }
                        ]
                    }
                }
            ]
        },
