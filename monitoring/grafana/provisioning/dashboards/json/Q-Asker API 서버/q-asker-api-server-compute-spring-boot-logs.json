            "gridPos": { "h": 4, "w": 4, "x": 20, "y": 7 },
            "datasource": {
                "type": "loki",
                "uid": "P8E80F9AEF21F6940"
            },
            "targets": [
                {
                    "expr": "sum by (host) (count_over_time({host=~\"$host\", app=~\"$app\"} |~ \"$search\" [$__auto]))",
