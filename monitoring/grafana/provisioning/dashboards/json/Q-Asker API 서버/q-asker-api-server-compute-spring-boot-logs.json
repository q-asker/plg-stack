        {
            "title": "로그 볼륨 (시간대별)",
            "description": "시간대별 로그 발생량 추이. 급증 구간은 에러 또는 트래픽 폭증을 의미.",
            "type": "barchart",
            "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
            "datasource": {
                "type": "loki",
                "uid": "P8E80F9AEF21F6940"
            },
            "targets": [
                {
                    "expr": "sum(count_over_time({host=~\"$host\", app=~\"$app\"} |~ \"$search\" [$__auto]))",
                    "legendFormat": "전체",
                    "refId": "A"
                },
                {
                    "expr": "sum(count_over_time({host=~\"$host\", app=~\"$app\", level=\"ERROR\"} |~ \"$search\" [$__auto]))",
                    "legendFormat": "ERROR",
                    "refId": "B"
                },
                {
                    "expr": "sum(count_over_time({host=~\"$host\", app=~\"$app\", level=\"WARN\"} |~ \"$search\" [$__auto]))",
                    "legendFormat": "WARN",
                    "refId": "C"
                },
                {
                    "expr": "sum(count_over_time({host=~\"$host\", app=~\"$app\", level=\"INFO\"} |~ \"$search\" [$__auto]))",
                    "legendFormat": "INFO",
                    "refId": "D"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 80,
                        "stacking": {
                            "mode": "normal"
                        }
                    }
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "ERROR" },
                        "properties": [
                            { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
                        ]
                    },
                    {
                        "matcher": { "id": "byName", "options": "WARN" },
                        "properties": [
                            { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
                        ]
                    },
                    {
                        "matcher": { "id": "byName", "options": "전체" },
                        "properties": [
                            { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
                        ]
                    },
                    {
                        "matcher": { "id": "byName", "options": "INFO" },
                        "properties": [
                            { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
                        ]
                    }
                ]
            },
            "options": {
                "tooltip": {
                    "mode": "multi"
                }
            }
        },
        {
