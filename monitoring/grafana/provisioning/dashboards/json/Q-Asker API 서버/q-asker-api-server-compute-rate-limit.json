      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (tier) (increase(rate_limit_rejected_total{scope=\"global\"}[5m]))",
          "legendFormat": "{{tier}} 차단",
          "refId": "A"
