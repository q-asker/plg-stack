# =============================================================
# #4 Monitoring 인스턴스 환경변수
# 실제 값으로 교체 후 .env로 저장
# =============================================================

# Grafana 관리자 비밀번호
GRAFANA_ADMIN_PASSWORD=changeme

# HeatWave MySQL 접속 DSN (Alloy MySQL exporter용)
# 형식: user:password@tcp(host:port)/
# 필요 권한: PROCESS, REPLICATION CLIENT, SELECT
#
# HeatWave에서 모니터링 계정 생성:
#   CREATE USER 'alloy_monitor'@'%' IDENTIFIED BY 'secure_password';
#   GRANT PROCESS, REPLICATION CLIENT, SELECT ON *.* TO 'alloy_monitor'@'%';
#   FLUSH PRIVILEGES;
#
# 주의: HeatWave 관리형 서비스에서 PROCESS/REPLICATION CLIENT 권한이
# 거부될 수 있음. 거부 시 해당 지표(스레드 목록, 복제 상태)는 수집 불가.
MYSQL_DSN=alloy_monitor:secure_password@tcp(heatwave-endpoint.oraclevcn.com:3306)/

# Spring Boot 인스턴스 호스트 (Prometheus scrape용)
SPRINGBOOT_HOST=springboot.example.com
