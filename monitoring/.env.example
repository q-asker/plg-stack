# =============================================================
# Monitoring 스택 환경 변수 템플릿
# 사용법: 이 파일을 monitoring/.env로 복사 후 실제 값 입력
#         실제 .env는 .gitignore 적용되어 커밋되지 않음 (헌법 III)
# =============================================================

# ═══════════════════════════════════════════════════════════
# ① Grafana
# ═══════════════════════════════════════════════════════════
# Grafana admin 계정 비밀번호 (강한 값 사용, 기본값 changeme 금지)
GRAFANA_ADMIN_PASSWORD=

# ═══════════════════════════════════════════════════════════
# ② Alloy MySQL Exporter (HeatWave)
# ═══════════════════════════════════════════════════════════
# 형식: user:password@tcp(host:3306)/database
# 필요 권한: PROCESS, REPLICATION CLIENT, SELECT
MYSQL_DSN=

# ═══════════════════════════════════════════════════════════
# ③ Slack 알림 (Grafana 알림 + 백업/검증 실패 알림 공통)
# ═══════════════════════════════════════════════════════════
# 실패 시 webhook으로 POST. 미설정 시 알림 스킵(로그만 기록).
SLACK_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════
# ④ OCI Object Storage 백업 저장소 (T2~T6)
# ═══════════════════════════════════════════════════════════
# Always Free 20 GiB Standard tier. 모니터링 인스턴스와 동일 region 권장.
OCI_BUCKET_NAME=q-asker-monitoring-backup

# tenancy namespace — 다음 명령으로 확인:
#   oci os ns get --auth instance_principal
OCI_NAMESPACE=

# OCI-3 인스턴스가 위치한 region (예: ap-seoul-1, ap-chuncheon-1)
OCI_REGION=ap-seoul-1

# 인증 방식: instance_principal (권장, 키 파일 불필요) | api_key (fallback)
OCI_AUTH_MODE=instance_principal

# api_key 모드일 때만 채움 (예: /home/ubuntu/.oci/config).
# instance_principal 모드면 빈 값 유지.
OCI_CONFIG_FILE=

# ═══════════════════════════════════════════════════════════
# ⑤ 백업 보존/한도 정책 (T3·T6)
# ═══════════════════════════════════════════════════════════
# 백업 객체 보존 기간(일). 버킷 lifecycle 규칙과 이중 안전망.
BACKUP_RETENTION_DAYS=7

# 무료 한도(bytes). T6 verify.sh가 사용량 90% 도달 시 Slack 임계 알림.
# 21474836480 = 20 * 1024^3 = 20 GiB
BACKUP_FREE_LIMIT_BYTES=21474836480
