# =============================================================
# Monitoring 스택 환경 변수 템플릿
# 사용법: 이 파일을 monitoring/.env로 복사 후 실제 값 입력
#         실제 .env는 .gitignore 적용되어 커밋되지 않음 (헌법 III)
# =============================================================

# ═══════════════════════════════════════════════════════════
# ① Grafana
# ═══════════════════════════════════════════════════════════
# Grafana admin 계정 비밀번호 (강한 값 사용, 기본값 changeme 금지)
GRAFANA_ADMIN_PASSWORD=

# ═══════════════════════════════════════════════════════════
# ② Alloy MySQL Exporter (HeatWave)
# ═══════════════════════════════════════════════════════════
# 형식: user:password@tcp(host:3306)/database
# 필요 권한: PROCESS, REPLICATION CLIENT, SELECT
MYSQL_DSN=

# ═══════════════════════════════════════════════════════════
# ③ Slack 알림 (Grafana 알림 + 백업/검증 실패 알림 공통)
# ═══════════════════════════════════════════════════════════
# 실패 시 webhook으로 POST. 미설정 시 알림 스킵(로그만 기록).
SLACK_ERROR_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════
# ④ OCI Object Storage 백업 저장소 (T2~T6)
# ═══════════════════════════════════════════════════════════
# Always Free 20 GB Standard tier. Terraform으로 관리 (terraform/oci/object_storage_monitoring.tf).
OCI_BUCKET_NAME=qasker-monitoring-backup

# tenancy namespace — Terraform apply 후 output 참조:
#   terraform output monitoring_backup_bucket_namespace
OCI_NAMESPACE=

# OCI-3 인스턴스가 위치한 region (프로젝트 기본: ap-chuncheon-1)
OCI_REGION=ap-chuncheon-1

# OCI CLI config 파일 경로 (API Key 방식)
OCI_CONFIG_FILE=/home/ubuntu/.oci/config

# ~/.oci/config 내 프로필 이름 (Writer/Reader 분리 — Terraform으로 IAM 생성됨)
#   BACKUP_MON_WRITER: backup.sh용 (PUT/HEAD/DELETE만 허용)
#   BACKUP_MON_READER: restore.sh + backup.sh 인라인 검증·저장소 조회용 (GET/HEAD만 허용)
OCI_WRITER_PROFILE=BACKUP_MON_WRITER
OCI_READER_PROFILE=BACKUP_MON_READER

# ═══════════════════════════════════════════════════════════
# ⑤ 백업 보존/한도 정책
# ═══════════════════════════════════════════════════════════
# 백업 객체 보존 기간(일). 버킷 lifecycle 규칙과 이중 안전망.
BACKUP_RETENTION_DAYS=7

# 무료 한도(bytes). backup.sh가 사용량 90% 도달 시 Slack 임계 알림.
# 20000000000 = 20 * 10^9 = 20 GB (OCI Always Free Object Storage 실제 한도, ≈18.6 GiB)
BACKUP_FREE_LIMIT_BYTES=20000000000
