# ============================================================
# /etc/oci-mysql-backup/env (EnvironmentFile for systemd)
# ============================================================
# 배포 후 /etc/oci-mysql-backup/env에 배치하고 chmod 600 적용.
# 셸 export 형식이 아니라 KEY=VALUE 단순 형식 (systemd 파싱).
# 주석은 # 시작줄만.

# ─── MySQL 접속 정보 (필수) ───
MYSQL_HOST=ADMIN.subnet.vcn.oraclevcn.com
MYSQL_PORT=3306
MYSQL_USER=backup_readonly
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=qaskerdb

# 옵션: MYSQL_CNF 파일 사용으로 password CLI 노출 회피
# 설정 시 위 MYSQL_PASSWORD는 무시됨.
# 파일 예:
#   [client]
#   user=backup_readonly
#   password=xxx
# chmod 600 /etc/oci-mysql-backup/.my.cnf
# MYSQL_CNF=/etc/oci-mysql-backup/.my.cnf

# ─── OCI Object Storage (T3 산출물) ───
BUCKET=qasker-mysql-backup
OCI_PROFILE=BACKUP_WRITER
# 업로드 후 재다운로드 무결성 검증용 프로필 (GET 권한). restore.sh와 동일한 READER 사용.
VERIFY_OCI_PROFILE=BACKUP_READER

# ─── 저장소 임계 경고 (선택) ───
# 무료 20GB는 tenancy 전체 Object Storage 합산이라 총량을 감시한다(전 버킷 approximateSize 합).
# 80%/90% 2단계 도달 시 Slack 경고 → 대응은 백업 주기 늘리기(timer/cron).
BACKUP_FREE_LIMIT_BYTES=20000000000   # 20 GB (전 버킷 합산)
# 총량 조회 전용 프로필: 'read buckets' 권한 필요. BACKUP_WRITER 스코프로는 불가.
# 미설정/권한없음이면 경고만 스킵(백업은 정상).
USAGE_OCI_PROFILE=BACKUP_USAGE_READER

# ─── 상태·메트릭·락 파일 경로 (기본값 유지 권장) ───
STATE_FILE=/var/lib/oci-mysql-backup/state.json
METRIC_FILE=/var/lib/node_exporter/textfile_collector/oci_mysql_backup.prom
LOCK_FILE=/var/lock/oci-mysql-backup.lock

# ─── 옵션 ───
# DRY_RUN=1 로 두면 upload 생략 (검증용). production은 반드시 0 또는 미설정.
DRY_RUN=0

# ─── Slack 알림 (선택) ───
# 백업 성공/실패 시 Slack webhook으로 알림. 미설정 시 알림만 스킵(백업은 정상 동작).
# 백업 전용 채널 — Grafana 에러 알림(SLACK_ERROR_WEBHOOK_URL)과 다른 채널.
# 실제 값은 /etc/oci-mysql-backup/env 에만 두고 커밋 금지.
# SLACK_BACKUP_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ─── T7 헬스체크 (T4 backup·T8 restore 공용 참조) ───
BASELINE_FILE=/etc/oci-mysql-backup/healthcheck.baseline.yml
