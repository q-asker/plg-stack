# =============================================================
# #2 Spring Boot 인스턴스 (OCI-2 ARM) 환경변수
# 실제 값으로 교체 후 .env로 저장
# =============================================================

# Loki 엔드포인트 (OCI-3 Monitoring 인스턴스)
# Alloy가 Docker 컨테이너 로그를 수집하여 전송하는 대상
LOKI_URL=http://monitoring.example.com:3100/loki/api/v1/push

# Prometheus remote_write 엔드포인트 (OCI-3 Monitoring 인스턴스)
# Alloy가 시스템 메트릭 + LibreOffice 프로세스 메트릭을 전송하는 대상
PROMETHEUS_URL=http://monitoring.example.com:9090/api/v1/write
